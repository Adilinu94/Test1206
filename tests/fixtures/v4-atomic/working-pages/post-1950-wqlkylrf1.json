  "schema_observations": {
    "container_widgetType_redundancy": "Atomic containers (e-flexbox, e-div-block) sometimes have BOTH elType and widgetType set to the same value (e.g. elType: 'e-flexbox', widgetType: 'e-flexbox'). This appears to be a quirk of how Elementor persists atomic container nodes — both fields point to the container type. Headless e-flexbox, e-div-block, e-image etc.",
    "e_button_link_wrapped_shape": "On 1950 the e-button link uses the full wrapped shape: { $$type: 'link', value: { href: { $$type: 'string', value: '/contact' }, isTargetBlank: { $$type: 'boolean', value: false }, tag: { $$type: 'string', value: 'a' } } }. This is the canonical/portable shape; the simplified string-only form (1953) is also accepted by Elementor but is less safe.",
    "e_image_two_shapes": "e-image src can be either: (a) id-based { id: { $$type: 'image-attachment-id', value: 1184 }, url: null } (Invariant IV — no url key when id set) OR (b) url-based { url: { $$type: 'url', value: 'https://...' } } (no id key). The 'url: null' literal in the id-based shape is critical — elementor-add-element description says 'Invariant IV: url omitted when id is set' but the Elementor storage format actually keeps the key with a null value.",
    "container_link_default": "Containers have settings.link: { $$type: 'link', value: [] } when not used (empty array inside value)",
    "grid_layout": "display: grid is supported with grid-template-columns: '1fr 1fr 1fr' (3-column grid) — wraps correctly as string property",
    "border_radius_complete_shape": "border-radius always uses all 4 corners: { start-start, start-end, end-end, end-start } — even when all four are equal to 0 (full object, not shorthand)",
    "padding_dimensions": "padding uses 'dimensions' with block-start/block-end/inline-start/inline-end (logical properties, not top/right/bottom/left)",
    "h1_h2_via_tag": "e-heading tag property controls h1-h6; default appears to be h1 if not set",
    "framer_image_urls": "e-image with Framer-CDN-URLs works (no need to upload to WP first) — elementor-add-element description: 'Provide either image_id (from media library) or image_url'"
  }
}
