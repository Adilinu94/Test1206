<?xml version="1.0"?>
<psalm
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"

    errorLevel="4"
    findUnusedCode="false"
    findUnusedBaselineEntry="true"
    findUnusedPsalmSuppress="true"
    resolveFromConfigFile="true"
    useDocblockTypes="true"
    disableSuppressAll="false"

    cacheDirectory=".psalm-cache"
>
    <!-- Phase 0.5.5: SAST-Integration with taint-analysis mode
         Detects XSS, SQLi, and other taint-flow vulnerabilities
         in the novamira-adrianv2 V2-Plugin.
         Audit evidence: novamira-improvement-2026-06/report.md, item D1.
    -->

    <projectFiles>
        <directory name="includes/" />
        <file name="novamira-adrianv2.php" />

        <ignoreFiles>
            <directory name=".psalm-cache/" />
            <directory name="novamira-improvement-2026-06/" />
            <directory name="vendor/" />
        </ignoreFiles>
    </projectFiles>

    <!-- Taint analysis for XSS / SQLi detection -->
    <taintAnalysis>
        <!-- Mark WordPress escape functions as sanitizing -->
        <safeFunction name="esc_html"        type="html" />
        <safeFunction name="esc_attr"        type="html" />
        <safeFunction name="esc_url"         type="html" />
        <safeFunction name="esc_textarea"    type="html" />
        <safeFunction name="esc_js"          type="html" />
        <safeFunction name="wp_kses"         type="html" />
        <safeFunction name="wp_kses_post"    type="html" />
        <safeFunction name="wp_strip_all_tags" type="html" />
        <safeFunction name="sanitize_text_field" type="html" />
        <safeFunction name="sanitize_title"  type="html" />
        <safeFunction name="sanitize_html_class" type="html" />
        <safeFunction name="absint"          type="sql" />
        <safeFunction name="intval"          type="sql" />

        <!-- Mark DB write functions as sinks requiring sanitized input -->
        <sinkFunction name="update_post_meta"   types="sql" />
        <sinkFunction name="add_post_meta"      types="sql" />
        <sinkFunction name="wp_insert_post"     types="sql" />
        <sinkFunction name="wp_update_post"     types="sql" />
        <sinkFunction name="wpdb::insert"       types="sql" />
        <sinkFunction name="wpdb::update"       types="sql" />

        <!-- Mark echo/output functions as HTML sinks -->
        <sinkFunction name="echo"               types="html" />
        <sinkFunction name="wp_json_encode"     types="html" />
    </taintAnalysis>

    <!-- Fake stubs for WordPress functions Psalm can't resolve -->
    <stubs>
        <file name="vendor/php-stubs/wordpress-stubs/wordpress-stubs.php" />
    </stubs>

    <!-- Treat all files as if they run inside WordPress -->
    <issueHandlers>
        <!-- False positives from WordPress globals -->
        <UndefinedGlobalVariable errorLevel="suppress">
            <errorLevel type="suppress">
                <referencedVariable name="$wpdb" />
            </errorLevel>
        </UndefinedGlobalVariable>

        <!-- WordPress functions defined at runtime -->
        <UndefinedFunction>
            <errorLevel type="suppress">
                <referencedFunction name="wp_register_ability" />
                <referencedFunction name="add_action" />
                <referencedFunction name="current_user_can" />
                <referencedFunction name="get_post" />
                <referencedFunction name="get_post_meta" />
                <referencedFunction name="update_post_meta" />
                <referencedFunction name="get_permalink" />
                <referencedFunction name="admin_url" />
                <referencedFunction name="wp_insert_post" />
                <referencedFunction name="wp_update_post" />
                <referencedFunction name="is_wp_error" />
                <referencedFunction name="wp_slash" />
                <referencedFunction name="wp_json_encode" />
                <referencedFunction name="wp_strip_all_tags" />
                <referencedFunction name="wp_kses_post" />
                <referencedFunction name="sanitize_text_field" />
                <referencedFunction name="sanitize_html_class" />
                <referencedFunction name="sanitize_title" />
                <referencedFunction name="esc_html" />
                <referencedFunction name="esc_attr" />
                <referencedFunction name="esc_url" />
                <referencedFunction name="sanitize_file_name" />
            </errorLevel>
        </UndefinedFunction>

        <!-- WordPress constants defined at runtime -->
        <UndefinedConstant>
            <errorLevel type="suppress">
                <referencedConstant name="ABSPATH" />
                <referencedConstant name="ELEMENTOR_VERSION" />
            </errorLevel>
        </UndefinedConstant>

        <!-- Classes loaded by WordPress autoloader -->
        <UndefinedClass>
            <errorLevel type="suppress">
                <referencedClass name="Novamira\Adrians\Helpers" />
                <referencedClass name="Novamira\Adrians\Guards" />
            </errorLevel>
        </UndefinedClass>
    </issueHandlers>
</psalm>
