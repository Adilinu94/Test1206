# Framer V4 Pipeline — Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
# .env wird niemals committet (steht in .gitignore).

# ── Workspace ────────────────────────────────────────────────────────────────
# Verzeichnis fuer Pipeline-Artefakte (v4-tree.json, image-map.json, etc.)
PIPELINE_WORKSPACE=./.pipeline

# Pfad zum lokalen FramerExport-Checkout
FRAMER_EXPORT_DIR=../framer-export

# ── WordPress / MCP ──────────────────────────────────────────────────────────
# Standard-Zielumgebung (testseite, treetsshop, solar-local)
WP_DEFAULT_ENV=solar-local

# MCP JSON-RPC 2.0 Endpoint (solar.local)
WP_API_URL=https://solar.local/wp-json/mcp/novamira

# Basic Auth Credentials (WordPress Application Password)
WP_API_USERNAME=Adrian
WP_API_PASSWORD=

# MCP Transport (fuer @automattic/mcp-wordpress-remote)
MCP_TRANSPORT=@automattic/mcp-wordpress-remote@latest

# Timeout pro MCP-Request in ms
MCP_TIMEOUT_MS=60000

# Maximale Retry-Versuche bei 5xx/Timeout
MCP_RETRY_MAX=3

# Backoff-Strategie: "exponential" (1000ms * 2^attempt + jitter)
MCP_RETRY_BACKOFF=exponential

# ── Validation ───────────────────────────────────────────────────────────────
# Mindest-Score fuer Pre-Build-Validierung (0-100)
PIPELINE_MIN_VALIDATION_SCORE=85

# Build abbrechen wenn Layout-Fehler gefunden werden
PIPELINE_FAIL_ON_BROKEN_LAYOUT=true

# ── Performance ──────────────────────────────────────────────────────────────
# Parallele Ausfuehrung unabhaengiger Sub-Steps
PIPELINE_PARALLEL_PHASES=true

# Batch-Groesse fuer Batch-MCP-Calls (max 30)
PIPELINE_BATCH_SIZE=10

# MCP Discovery Cache TTL in Sekunden
PIPELINE_DISCOVERY_CACHE_TTL=3600
