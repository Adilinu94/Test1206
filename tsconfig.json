{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "scripts/**/*.js", "wizard.js"],
  "exclude": ["node_modules", "dist", "tests", "tools", "docs", "novamira-skill", "novamira-adrianv2", "novamira-ability-code-injector", "tasks", "FramerExport", "research"]
}
