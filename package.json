{
  "name": "framer-v4-pipeline-v2",
  "version": "0.20.0",
  "description": "Standalone Framer to Elementor V4 pre-build pipeline scripts",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/pipeline.test.js tests/lib/*.test.js tests/inspect-v4-schemas.test.js tests/phase-1-bug-2-regression.test.js tests/sprint19-fixes.test.js",
    "test:e2e": "node --import tsx --test tests/e2e.test.js",
    "test:all": "node --import tsx --test tests/pipeline.test.js tests/lib/*.test.js tests/sprint19-fixes.test.js && node --import tsx --test tests/e2e.test.js && node --import tsx --test tests/integration.test.js",
    "test:visual": "node --import tsx --test tests/visual-regression.test.js",
    "test:integration": "node --import tsx --test tests/integration.test.js",
    "test:phase4": "node --import tsx --test tests/lib/elementor-version.test.js tests/lib/wp-theme.test.js tests/lib/pro-fallback.test.js",
    "test:phase5": "node --import tsx --test tests/lib/framer-cache.test.js tests/lib/asset-batch-uploader.test.js tests/lib/pipeline-waves.test.js",
    "test:lib": "node --import tsx --test tests/lib/*.test.js",
    "framer-cache:stats": "node -e \"import('./scripts/lib/framer-cache.js').then(m => console.log(JSON.stringify(m.getFramerCacheStats(), null, 2)))\"",
    "framer-cache:clear": "node -e \"import('./scripts/lib/framer-cache.js').then(m => m.clearFramerCache())\"",
    "test:bridge": "node scripts/lib/mcp-bridge.js --self-test",
    "validate": "node scripts/framer-pre-build-validate.js",
    "preflight-check": "node scripts/preflight-check.js",
    "preflight:experiments": "node scripts/preflight/ensure-elementor-experiments.js",
    "preflight:experiments-dry": "node scripts/preflight/ensure-elementor-experiments.js --dry-run",
    "preflight:unframer": "node scripts/preflight/check-unframer-connectivity.js",
    "preflight:xml-match": "node scripts/preflight/verify-xml-project-match.js",
    "schema-validate": "node scripts/validate-v4-tree.js",
    "check-binding": "node scripts/verify-build-binding.js",
    "token-extract": "node scripts/design-token-extractor.js",
    "gc-generate": "node scripts/generate-global-classes.js",
    "gc-execute": "node scripts/generate-global-classes.js --execute",
    "cross-validate": "node scripts/cross-validate-sources.js",
    "patch-media": "node scripts/patch-v4-tree-media-ids.js",
    "auto-scale": "node scripts/auto-scale-responsive.js",
    "dependency-graph": "node scripts/build-dependency-graph.js",
    "convert": "node scripts/convert-xml-to-v4.js",
    "asset-queue": "node scripts/asset-to-wp-media.js",
    "asset-upload": "node scripts/asset-to-wp-media.js --execute",
    "export-mcp-plan": "node scripts/export-mcp-xml.js",
    "widget-plan": "node scripts/html-to-widget-plan.js",
    "widget-plan-execute": "node scripts/html-to-widget-plan.js --execute",
    "sync-schema": "node scripts/sync-schema.js",
    "parallel": "node scripts/parallel-pre-build.js",
    "test:schema": "node scripts/sync-schema.js --validate",
    "visual-qa": "node scripts/visual-qa.js",
    "visual-qa-a11y": "node scripts/visual-qa.js --a11y",
    "check-v4": "node scripts/check-v4-requirements.js",
    "check-v4-auto": "node scripts/check-v4-requirements.js --auto-call",
    "dedup-qa": "node scripts/deduplicate-visual-qa.js",
    "apply-gv-ids": "node scripts/design-token-extractor.js --apply-response",
    "post-build-qa": "node scripts/run-post-build-qa.js",
    "section-compare": "node scripts/section-compare.js",
    "compare:hero": "node scripts/section-compare.js --framer-url ${FRAMER_PREVIEW_URL:?Set FRAMER_PREVIEW_URL in .env} --elementor-url ${WP_PREVIEW_URL:?Set WP_PREVIEW_URL in .env} --section hero --above-fold --open",
    "extract-components": "node scripts/extract-framer-components.js",
    "extract-interactions": "node scripts/extract-framer-interactions.js",
    "extract-forms": "node scripts/extract-framer-forms.js",
    "extract-dark-mode": "node scripts/extract-framer-dark-mode.js",
    "extract-animations": "node scripts/framer-animation-extractor.js",
    "auto-fix": "node scripts/post-build-auto-fix.js",
    "inject-code": "node scripts/inject-animation-code.js",
    "inject-animations": "node scripts/inject-animation-code.js --plan animation-plan.json",
    "inject-from-export": "node scripts/inject-animation-code.js --from-framer-export",
    "wizard-batch": "node wizard.js batch",
    "lint:version": "node scripts/lint-test-count.js",
    "measure-quality": "node scripts/measure-quality-metrics.js",
    "test:integration-live": "node --import tsx --test tests/integration.test.js -- --live",
    "profile-pipeline": "node scripts/profile-pipeline.js",
    "deploy-plugin": "bash novamira-adrianv2/scripts/deploy-plugin.sh",
    "session-init": "node scripts/session-init.js",
    "session-init:update-state": "node scripts/session-init.js --update-session-state",
    "css-fallback": "node scripts/css-fallback-extractor.js",
    "css-fallback:url": "node scripts/css-fallback-extractor.js --url",
    "css-fallback:html": "node scripts/css-fallback-extractor.js --html",
    "responsive": "node scripts/integrate-responsive.js",
    "responsive:with-css": "node scripts/integrate-responsive.js --css",
    "post-build": "node scripts/post-build-hook.js",
    "post-build:qa-only": "node scripts/post-build-hook.js --qa-only",
    "post-build:dry": "node scripts/post-build-hook.js --dry-run"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.10.0",
    "axe-core": "^4.12.1",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
